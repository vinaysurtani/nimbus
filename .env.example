# Copy this file to .env and fill in your values
# .env is gitignored and should never be committed

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PostgreSQL
POSTGRES_DB=nimbus
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me_before_deploying

# Gateway connection strings (used by Go services)
DB_URL=postgres://user:change_me_before_deploying@postgres:5432/nimbus?sslmode=disable
REDIS_URL=redis:6379

# Logging
LOG_LEVEL=info
